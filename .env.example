# ID do projeto Firebase
FB_PROJECT_ID=your-firebase-project-id

# Caminho para o service account JSON (relativo à raiz do projeto)
# Necessário apenas em produção — ignorado quando FIRESTORE_EMULATOR_HOST está definido
WHATSAPP_SERVICE_ACCOUNT=secrets/service_account.json

# Defina para apontar ao emulador local do Firestore (desenvolvimento)
# Remova ou deixe vazio em produção
FIRESTORE_EMULATOR_HOST=localhost:8080
